#!/bin/bash
# ============================================================================
# Pre-commit Hook — 熵增防护门禁
#
# 每次 git commit 前自动运行快速单元测试。
# 任何测试失败都将阻止提交。
#
# 安装方式（一次性）：
#   git config core.hooksPath .githooks
# ============================================================================

echo "[pre-commit] 运行快速测试..."

# 进入项目根目录
cd "$(dirname "$0")/.."

# 运行单元测试（仅标记为 unit 的快速测试）
python -m pytest tests/ -m "unit" -x -q --tb=line 2>&1

if [ $? -ne 0 ]; then
    echo ""
    echo "============================================"
    echo "  测试失败，提交被阻止。"
    echo "  请运行 'pytest tests/ -v' 查看完整输出。"
    echo "============================================"
    exit 1
fi

echo "[pre-commit] 所有测试通过。"
exit 0
